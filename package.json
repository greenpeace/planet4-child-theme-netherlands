{
	"name": "planet4-child-theme-netherlands",
	"description": "Child theme for Netherlands for the Planet 4 Wordpress project",
	"repository": "git@github.com:greenpeace/planet4-child-theme-netherlands.git",
	"author": "Greenpeace Netherlands",
	"license": "MIT",
	"scripts": {
		"start": "webpack serve --config webpack/webpack.config.dev.js",
		"build": "webpack --config webpack/webpack.config.prod.js",
		"postinstall": "ln -s -f ../../githooks/commit-msg .git/hooks/commit-msg && chmod +x githooks/commit-msg",
		"poststart": "ln -s -f ../../githooks/commit-msg .git/hooks/commit-msg && chmod +x githooks/commit-msg",
		"release": "npm run-script build && git add . && standard-version -a --no-verify",
		"dryrelease": "standard-version --dry-run",
		"lint": "eslint assets --ext .js,.jsx && stylelint 'assets/**/*.scss'",
		"lint:fix": "eslint --fix assets --ext .js,.jsx && stylelint --fix 'assets/**/*.scss'",
		"lint:js": "eslint assets --ext .js,.jsx",
		"lint:css": "stylelint 'assets/**/*.scss'",
		"lint:js:fix": "eslint --fix assets --ext .js,.jsx",
		"lint:css:fix": "stylelint --fix 'assets/**/*.scss'"
	},
	"devDependencies": {
		"@babel/core": "^7.14.3",
		"@babel/preset-env": "^7.14.2",
		"@babel/preset-react": "^7.13.13",
		"@pmmmwh/react-refresh-webpack-plugin": "^0.4.3",
		"@webpack-cli/serve": "^1.4.0",
		"@wordpress/dependency-extraction-webpack-plugin": "^3.1.3",
		"@wordpress/scripts": "^16.0.0",
		"autoprefixer": "^10.2.5",
		"babel-loader": "^8.2.2",
		"clean-webpack-plugin": "^3.0.0",
		"conventional-github-releaser": "^3.1.5",
		"css-loader": "^5.1.3",
		"css-minimizer-webpack-plugin": "^3.0.0",
		"del": "^6.0.0",
		"eslint": "^7.26.0",
		"eslint-plugin-no-jquery": "^2.6.0",
		"file-loader": "^6.2.0",
		"mini-css-extract-plugin": "^1.3.9",
		"node-sass": "^6.0.0",
		"postcss": "^8.2.15",
		"postcss-import": "^14.0.2",
		"postcss-loader": "^5.3.0",
		"postcss-preset-env": "^6.7.0",
		"react": "^17.0.2",
		"react-dom": "^17.0.2",
		"react-reconciler": "^0.26.1",
		"react-refresh": "^0.10.0",
		"sass": "^1.32.13",
		"sass-loader": "^11.1.1",
		"standard-version": "^9.3.0",
		"style-loader": "^2.0.0",
		"stylelint": "^13.13.1",
		"url-loader": "^4.1.1",
		"webpack": "^5.37.0",
		"webpack-cli": "^4.7.0",
		"webpack-dev-server": "^4.0.0-beta.3",
		"webpack-manifest-plugin": "^3.1.1",
		"webpack-merge": "^5.7.3"
	},
	"dependencies": {
		"bootstrap": "^5.0.1",
		"popper.js": "^2.0.0-next.4"
	},
	"standard-version": {
		"scripts": {
			"prerelease": "git checkout -b release",
			"postcommit": "git checkout develop && git merge release",
			"pretag": "git checkout master && git merge release",
			"posttag": "git branch -d release"
		}
	},
	"version": "4.16.0"
}
